# /etc/nginx/conf.d/chatbot.dati.gov.it.conf
#
# Template vhost SIMBA chatbot su VM AgID FastWeb.
#
# Sulla stessa VM gira anche Cruscotto Italia (cruscotto-italia.dati.gov.it).
# I 2 vhost sono separati ma condividono:
#   - nginx server (porte 80/443)
#   - /etc/nginx/.htpasswd-stats (auth per dashboard analytics)
#   - certbot Let's Encrypt (o cert AgID separati per i 2 domini)
#
# Punti chiave:
#   - access_log / error_log dedicati (no log promiscui con Cruscotto)
#   - /simba-stats/ dashboard analytics protetta htpasswd
#   - location proxy_pass verso container Docker SIMBA
#
# Pre-flight VM AgID per stack SIMBA:
#   - Container Docker SIMBA up (porte interne 3001/3002/3003/3004/8000/8080/11434)
#   - Ollama con GPU passthrough (nvidia-container-toolkit)
#   - /var/www/simba-stats/ creato e gestito dal cron analytics
#     (vedi deploy/cron/simba-monitoring)

server {
    server_name chatbot.dati.gov.it;

    # ── Log dedicati per vhost (separazione da Cruscotto Italia) ──────────
    access_log /var/log/nginx/chatbot.access.log;
    error_log  /var/log/nginx/chatbot.error.log;

    # ── Statistiche SIMBA private (htpasswd) ──────────────────────────────
    # Aggregator: cron orario via deploy/cron/simba-monitoring
    # Output: /var/www/simba-stats/{stats.json,index.html}
    location ^~ /simba-stats/ {
        set $service "simba-stats";
        alias /var/www/simba-stats/;
        index index.html;
        auth_basic "Statistiche SIMBA";
        auth_basic_user_file /etc/nginx/.htpasswd-stats;
        add_header X-Robots-Tag "noindex, nofollow" always;
        add_header X-Content-Type-Options "nosniff" always;
    }

    # ── Security headers ──────────────────────────────────────────────────
    add_header X-Content-Type-Options "nosniff" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header Content-Security-Policy "default-src 'self'; connect-src 'self' https: http:; frame-ancestors 'self';" always;
    add_header X-Frame-Options "SAMEORIGIN" always;

    # ── Analytics service ─────────────────────────────────────────────────
    location /analytics-api/ {
        set $service "analytics-api";
        proxy_pass http://127.0.0.1:3004/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 30s;
        proxy_connect_timeout 10s;
    }

    location ~ ^/analytics(/.*)?$ {
        set $service "analytics-ui";
        auth_basic "Analytics — accesso riservato";
        auth_basic_user_file /etc/nginx/.htpasswd-analytics;
        rewrite ^/analytics(/.*)?$ /chatbot/$1 break;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
    }

    # ── Backend API ───────────────────────────────────────────────────────
    location /api/ {
        set $service "api";
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 120s;
        proxy_connect_timeout 30s;
    }

    # ── Chatbot UI (frontend statico via Docker frontend container) ───────
    location /chatbot {
        set $service "chatbot-ui";
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ── Assets statici frontend ───────────────────────────────────────────
    location /assets/ {
        set $service "assets";
        proxy_pass http://127.0.0.1:8080/assets/;
        proxy_set_header Host $host;
    }

    # ── Admin (htpasswd su nginx, in aggiunta al JWT backend) ─────────────
    location ~ ^/admin(/.*)?$ {
        set $service "admin";
        auth_basic "Admin — accesso riservato";
        auth_basic_user_file /etc/nginx/.htpasswd;
        rewrite ^/admin(/.*)?$ /chatbot/$1 break;
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
    }

    # ── TLS ───────────────────────────────────────────────────────────────
    # CERT AgID: aggiornare path quando i cert sono disponibili.
    # In alternativa: certbot --nginx -d chatbot.dati.gov.it
    listen 443 ssl;
    http2 on;
    ssl_certificate     /etc/ssl/dati.gov.it/chatbot.dati.gov.it.fullchain.pem;
    ssl_certificate_key /etc/ssl/dati.gov.it/chatbot.dati.gov.it.privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
}

server {
    listen 80;
    server_name chatbot.dati.gov.it;
    return 301 https://$host$request_uri;
}
