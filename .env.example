# ── Rete ─────────────────────────────────────────────────────────────────────
SERVER_IP= <IP o FqDN (cambiare) >
MCP_PORT=3000
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ── Provider LLM ───────────────────────────────────
LLM_PROVIDER=ollama

# ── Ollama (locale) ───────────────────────────────────────────────────
# Locale:
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_PORT=3004
# Token per proteggere gli endpoint /stats/* (cambia in produzione!)
ANALYTICS_TOKEN=<changeme (cambiare) >
# Origin del chatbot per il CORS dell'analytics-service
CHATBOT_ORIGIN=<https://chatbot.yyyyyyy.dom (cambiare)>
# URL analytics visto dal frontend (lascia vuoto se usi nginx proxy)
VITE_ANALYTICS_URL=
VITE_ANALYTICS_TOKEN=<changeme (cambiare)>

# ── Endpoint SPARQL ───────────────────────────────────────────────────────────
# Endpoint SPARQL per la ricerca dataset.
# Default: lod.dati.gov.it (catalogo nazionale italiano)
# Cambiare se si usa un triplestore diverso (es. endpoint locale, altro catalogo)
# SPARQL_ENDPOINT=https://lod.dati.gov.it/sparql
SPARQL_ENDPOINT=
ADMIN_TOKEN=<simba-admin-2026-rev123 (cambiare)>
VITE_ADMIN_TOKEN=<simba-admin-2026-rev123 (cambiare)>
