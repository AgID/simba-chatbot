# ── Rete ─────────────────────────────────────────────────────────────────────
SERVER_IP= <IP o FqDN (cambiare) >
MCP_PORT=3000
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ── Provider LLM ───────────────────────────────────
LLM_PROVIDER=ollama

# ── Ollama (locale) ───────────────────────────────────────────────────
# Locale:
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_PORT=3004
# [VA-03] Protezione /stats/* e /simba-stats/ ora via BASIC-AUTH nginx (.htpasswd-*),
# non piu via token nel client. ANALYTICS_TOKEN resta opzionale (interno analytics-service).
ANALYTICS_TOKEN=<opzionale; vuoto = nessun controllo lato servizio>
# Origin del chatbot per il CORS dell'analytics-service
CHATBOT_ORIGIN=<https://chatbot.yyyyyyy.dom (cambiare)>
# URL analytics visto dal frontend (lascia vuoto se usi nginx proxy)
VITE_ANALYTICS_URL=

# ── Endpoint SPARQL ───────────────────────────────────────────────────────────
# Endpoint SPARQL per la ricerca dataset.
# Default: lod.dati.gov.it (catalogo nazionale italiano)
# Cambiare se si usa un triplestore diverso (es. endpoint locale, altro catalogo)
# SPARQL_ENDPOINT=https://lod.dati.gov.it/sparql
SPARQL_ENDPOINT=
# -- CORS --------------------------------------------------------------------
# [VA-03] Origin ammessi per le API (CSV). Vuoto = nessun cross-origin (default DENY, no reflection).
CORS_ORIGIN=<https://chatbot.yyyyyyy.dom (cambiare)>

# -- Admin: autenticazione (JWT) ---------------------------------------------
# [VA-03] Pannello admin con login server-side + JWT. Valori REALI in .env.admin (NON committato):
#   JWT_SECRET=<openssl rand -hex 32>
#   ADMIN_USER=admin
#   ADMIN_PASSWORD_HASH=<bcrypt; nel file raddoppiare $ in $$ per docker compose>
# Niente piu VITE_ADMIN_TOKEN (era esposto nel bundle client: rimosso).

# -- Token interno guardrail-service -----------------------------------------
# [VA-03] Uso INTERNO: header X-Admin-Token verso guardrail-service (porta 8000, non esposta).
# NON e il login admin. Non esporre al client.
ADMIN_TOKEN=<token interno guardrail (cambiare)>
